---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { getPath } from "@/utils/getPath";
import slug from "slug";
import config from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  timezone,
} = post.data;

const { Content, headings } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && (config.features?.dynamicOgImage ?? true)) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to config site OG image / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${config.site.title}`,
  author,
  description,
  pubDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};
---

<Layout {...layoutProps}>
  <!-- Reading progress bar -->
  <div class="progress-container bg-background fixed top-0 z-10 h-1 w-full">
    <div class="progress-bar bg-accent h-1 w-0" id="myBar"></div>
  </div>

  <Header />
  <main id="main-content" class="app-layout pt-4 pb-12">
    <h1
      transition:name={slug(title.replaceAll(".", "-"))}
      class="text-accent inline-block text-2xl font-bold sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {timezone} size="lg" />
    </div>

    <div class="relative mt-8">
      <div
        id="toc-rail"
        class="hidden xl:absolute xl:top-0 xl:bottom-0 xl:left-0 xl:z-10 xl:block xl:w-64 xl:-translate-x-[calc(100%+2rem)]"
      >
        <div class="xl:sticky xl:top-24">
          <TableOfContents headings={headings} />
        </div>
      </div>

      <article
        id="article"
        class="app-prose max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg) w-full"
      >
        <Content />
      </article>
    </div>

    <hr class="my-8 border-dashed" />

    <BackToTopButton />

    <SocialLinks showSocialLinks={false} />
  </main>
  <Footer />
</Layout>

<script>
  import { mountPostDetailsEnhancer } from "@/scripts/postDetailsEnhancer";

  function init() {
    mountPostDetailsEnhancer();
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
