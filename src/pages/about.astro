---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { SITE } from "@/config";
import profileImage from "@/assets/images/profile.jpg";
---

<Layout
  title={`About | ${SITE.title}`}
  description="About Gopal Krishnan — software engineer at Automattic, Canadian living in Sydney, dad, and coffee enthusiast."
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">About</h1>
      <Image
        src={profileImage}
        alt="Gopal Krishnan"
        width={450}
        height={669}
        class="rounded-lg"
      />
      <p>
        I'm Gopal, and I work at <a href="/posts/working-at-automattic/"
          >Automattic</a
        >. I'm a Canadian living in Sydney, Australia with my wife and son.
      </p>
      <p>When I'm not spending time with my family, I can also be found:</p>
      <ul>
        <li>Travelling</li>
        <li>Perfecting the art of making coffee</li>
        <li>Catching up on my movies and TV shows</li>
        <li>Working out</li>
        <li>Playing board games with my board game group</li>
      </ul>
      <p>
        While writing this page, I realized I've lived on three continents
        already. I'm hoping to make it to all seven soon!
      </p>
      <p>
        You can find my resume <a href="/resume.pdf">here</a>.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
