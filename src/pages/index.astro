---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { Image } from "astro:assets";
import avatarImage from "@/assets/images/avatar.jpg";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <div class="flex flex-col items-stretch gap-4 sm:flex-row">
        <a href="/about" class="mx-auto block sm:mx-0">
          <Image
            src={avatarImage}
            alt="Gopal Krishnan"
            width={160}
            height={160}
            class="rounded-full object-cover sm:h-full sm:w-auto"
            style="height: 100%; width: auto;"
          />
        </a>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center justify-center gap-2 sm:justify-start">
            <h1
              class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl"
            >
              Hey, I'm Gopal
            </h1>
            <a
              target="_blank"
              href="/rss.xml"
              class="inline-block"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss
                width={20}
                height={20}
                class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
              />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>

          <p>
            Welcome to my corner of the internet where I write about being a
            developer, dad and a coffee enthusiast.
          </p>
          {
            SOCIALS.length > 0 && (
              <div class="mt-4 flex max-sm:flex-col sm:items-center">
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    {
      sortedPosts.length > 0 && (
        <section id="posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Posts</h2>
          <ul>
            {sortedPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
